# SnapCut AI - Environment Variables Example
# Copy this file to `.env` and replace the placeholders with your actual keys
# IMPORTANT: Never commit `.env` to git! (It's already in .gitignore)
# Keep local and Vercel values separate so test traffic does not hit production automations.

# Supabase
VITE_SUPABASE_URL=YOUR_SUPABASE_URL
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Public app URL
# Local example: http://localhost:8080
# Vercel example: https://your-project.vercel.app
VITE_APP_URL=http://localhost:8080

# Razorpay API Key (Get from https://dashboard.razorpay.com/)
# - Use Test Mode keys for development
# - Use Live Mode keys for production
VITE_RAZORPAY_KEY_ID=rzp_test_YourTestKeyIdHere

# Background removal webhook
# Use a separate webhook for local testing and a different one for Vercel/production.
VITE_REMOVE_BACKGROUND_WEBHOOK_URL=https://your-local-or-prod-n8n/webhook/remove-background

# Purchase success webhook
# Use a separate webhook for local testing and a different one for Vercel/production.
VITE_PURCHASE_WEBHOOK_URL=https://your-local-or-prod-n8n/webhook/purchase-made

# Note: RAZORPAY_KEY_SECRET should ONLY be used on your backend server!
# DO NOT put the Key Secret here or anywhere in client-side code!
# RAZORPAY_KEY_SECRET=your_backend_only_secret_here
